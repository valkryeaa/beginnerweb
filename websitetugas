<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AutoGarage — Dark Luxury Automotive Experience</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/aos@2.3.1/dist/aos.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<style>
/* ─── ROOT VARIABLES ─── */
:root {
  --black: #0F0F0F;
  --black2: #1C1C1C;
  --gray: #2D2D2D;
  --silver: #BFC0C0;
  --silver-light: #D9D9D9;
  --white: #FFFFFF;
  --glass: rgba(255,255,255,0.04);
  --glass-border: rgba(255,255,255,0.08);
  --glass-border-hover: rgba(255,255,255,0.18);
  --shadow: 0 8px 40px rgba(0,0,0,0.6);
  --shadow-hover: 0 20px 60px rgba(0,0,0,0.8);
  --glow: 0 0 30px rgba(191,192,192,0.15);
  --glow-hover: 0 0 50px rgba(191,192,192,0.25);
  --font-head: 'Montserrat', sans-serif;
  --font-body: 'Sora', sans-serif;
  --radius: 12px;
  --radius-sm: 6px;
}

/* ─── RESET & BASE ─── */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; font-size: 16px; }
body {
  background: var(--black);
  color: var(--white);
  font-family: var(--font-body);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ─── SCROLL PROGRESS ─── */
#progress {
  position: fixed; top: 0; left: 0; height: 2px; z-index: 10000;
  background: linear-gradient(90deg, #555, #BFC0C0, #fff);
  width: 0%; transition: width .08s linear;
}

/* ─── LOADER ─── */
#loader {
  position: fixed; inset: 0; background: var(--black); z-index: 99999;
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 28px;
}
.loader-word {
  font-family: var(--font-head); font-size: clamp(2.5rem,8vw,5rem);
  font-weight: 900; letter-spacing: 10px; text-transform: uppercase;
  background: linear-gradient(135deg, #555 0%, #BFC0C0 50%, #fff 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  animation: loader-pulse 1.5s ease-in-out infinite;
}
@keyframes loader-pulse { 0%,100%{opacity:.6} 50%{opacity:1} }
.loader-track { width: 240px; height: 1px; background: #222; }
.loader-fill { height: 100%; background: linear-gradient(90deg,#444,#BFC0C0,#fff); animation: lfill 2.2s ease forwards; }
@keyframes lfill { from{width:0%} to{width:100%} }
.loader-sub { font-size: .65rem; letter-spacing: 5px; color: #555; text-transform: uppercase; }

/* ─── PARTICLES ─── */
#ptx { position: fixed; inset: 0; pointer-events: none; z-index: 1; }
.ptx-dot {
  position: absolute; border-radius: 50%; background: #BFC0C0;
  animation: ptx-rise linear infinite;
}
@keyframes ptx-rise {
  0% { transform: translateY(110vh) scale(0); opacity: 0; }
  10% { opacity: .35; }
  90% { opacity: .1; }
  100% { transform: translateY(-10vh) scale(1); opacity: 0; }
}

/* ─── NAVBAR ─── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
  padding: 22px 6%; display: flex; align-items: center; justify-content: space-between;
  transition: all .4s ease;
}
nav.stuck {
  background: rgba(15,15,15,.92);
  backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  border-bottom: 1px solid var(--glass-border);
  padding: 15px 6%;
}
.nav-logo {
  font-family: var(--font-head); font-size: 1.4rem; font-weight: 900;
  letter-spacing: 4px; text-transform: uppercase; text-decoration: none;
  background: linear-gradient(135deg,#888,#BFC0C0,#fff);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.nav-logo span { -webkit-text-fill-color: rgba(255,255,255,.25); font-weight: 400; }
.nav-menu { display: flex; align-items: center; gap: 36px; list-style: none; }
.nav-menu a {
  font-size: .72rem; letter-spacing: 2.5px; text-transform: uppercase;
  color: rgba(255,255,255,.5); text-decoration: none; font-weight: 500;
  position: relative; transition: color .3s;
}
.nav-menu a::after {
  content: ''; position: absolute; bottom: -5px; left: 0; width: 0; height: 1px;
  background: var(--silver); transition: width .3s;
}
.nav-menu a:hover, .nav-menu a.active { color: var(--white); }
.nav-menu a:hover::after, .nav-menu a.active::after { width: 100%; }
.nav-ig {
  display: flex; align-items: center; gap: 8px;
  font-size: .7rem; letter-spacing: 1.5px; color: rgba(255,255,255,.5);
  text-decoration: none; border: 1px solid var(--glass-border);
  padding: 8px 18px; border-radius: 100px;
  backdrop-filter: blur(10px); transition: all .3s;
}
.nav-ig:hover { border-color: var(--silver-light); color: var(--white); box-shadow: var(--glow); }
.nav-ig svg { width: 14px; height: 14px; }
.hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; z-index: 1002; }
.hamburger span { width: 24px; height: 1.5px; background: var(--white); transition: all .3s; display: block; }
.hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(4.5px,4.5px); }
.hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(4.5px,-4.5px); }
.mob-menu {
  display: none; position: fixed; inset: 0; background: rgba(10,10,10,.98);
  backdrop-filter: blur(30px); z-index: 999;
  flex-direction: column; align-items: center; justify-content: center; gap: 36px;
}
.mob-menu.open { display: flex; }
.mob-menu a {
  font-family: var(--font-head); font-size: clamp(2rem,7vw,3rem);
  font-weight: 800; letter-spacing: 4px; text-transform: uppercase;
  color: rgba(255,255,255,.5); text-decoration: none; transition: color .3s;
}
.mob-menu a:hover { color: var(--white); }

/* ─── HERO ─── */
#hero {
  position: relative; height: 100vh; min-height: 680px;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.hero-bg {
  position: absolute; inset: 0; z-index: 0;
  background: url('https://images.unsplash.com/photo-1544636331-e26879cd4d9b?w=1920&q=80') center/cover no-repeat;
}
.hero-overlay {
  position: absolute; inset: 0; z-index: 1;
  background: linear-gradient(to bottom, rgba(15,15,15,.7) 0%, rgba(15,15,15,.5) 40%, rgba(15,15,15,.95) 100%);
}
.hero-grid-lines {
  position: absolute; inset: 0; z-index: 2;
  background-image:
    linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
  background-size: 80px 80px;
}
.hero-content {
  position: relative; z-index: 3; text-align: center;
  padding: 0 6%; max-width: 1000px;
}
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 10px;
  border: 1px solid rgba(255,255,255,.12); border-radius: 100px;
  padding: 7px 20px; margin-bottom: 32px;
  font-size: .65rem; letter-spacing: 4px; text-transform: uppercase;
  color: rgba(255,255,255,.45);
  animation: fadeUp .8s .5s both;
}
.hero-eyebrow span { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--silver); }
.hero-title {
  font-family: var(--font-head);
  font-size: clamp(4.5rem, 14vw, 11rem);
  font-weight: 900; line-height: .88; letter-spacing: -3px;
  background: linear-gradient(160deg, #fff 0%, #BFC0C0 40%, #888 80%, #555 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  animation: fadeUp .8s .7s both;
}
.hero-tagline {
  font-size: clamp(.95rem,2.5vw,1.3rem); font-weight: 300;
  color: rgba(255,255,255,.6); margin: 24px 0 14px; letter-spacing: .5px;
  animation: fadeUp .8s .9s both;
}
.hero-desc {
  font-size: .88rem; color: rgba(255,255,255,.35);
  max-width: 560px; margin: 0 auto 44px; line-height: 1.9;
  animation: fadeUp .8s 1.1s both;
}
.hero-cta { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; animation: fadeUp .8s 1.3s both; }
.btn { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-head);
  font-size: .7rem; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase;
  padding: 15px 36px; border-radius: var(--radius-sm); text-decoration: none;
  transition: all .35s; cursor: pointer; border: none; }
.btn-dark {
  background: var(--white); color: var(--black);
}
.btn-dark:hover { background: var(--silver-light); box-shadow: 0 0 40px rgba(255,255,255,.15); transform: translateY(-2px); }
.btn-ghost {
  background: transparent; color: var(--white);
  border: 1px solid rgba(255,255,255,.18);
}
.btn-ghost:hover { border-color: var(--silver); box-shadow: var(--glow); transform: translateY(-2px); }
.hero-scroll {
  position: absolute; bottom: 36px; left: 50%; transform: translateX(-50%);
  z-index: 3; display: flex; flex-direction: column; align-items: center; gap: 10px;
  animation: scroll-bob 2.5s ease-in-out infinite;
}
.hero-scroll span { font-size: .6rem; letter-spacing: 4px; color: rgba(255,255,255,.25); text-transform: uppercase; }
.hero-scroll-line { width: 1px; height: 50px; background: linear-gradient(to bottom,rgba(255,255,255,.3),transparent); }
@keyframes scroll-bob { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(8px)} }
@keyframes fadeUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }

/* ─── SHARED SECTION ─── */
.sec { position: relative; z-index: 10; padding: 130px 6%; }
.sec-dark { background: var(--black2); }
.sec-black { background: var(--black); }
.tag {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: .65rem; letter-spacing: 4px; text-transform: uppercase;
  color: var(--silver); font-weight: 600; margin-bottom: 18px;
}
.tag::before { content: ''; display: inline-block; width: 20px; height: 1px; background: var(--silver); }
h2.sec-title {
  font-family: var(--font-head); font-size: clamp(2.2rem,5.5vw,4.5rem);
  font-weight: 800; line-height: 1.05; letter-spacing: -1.5px;
  background: linear-gradient(135deg,#fff 0%,#BFC0C0 60%,#888 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.sec-sub { font-size: .9rem; color: rgba(255,255,255,.4); line-height: 1.9; max-width: 560px; margin-top: 18px; }
.divline { width: 50px; height: 1px; background: linear-gradient(90deg,var(--silver),transparent); margin: 22px 0; }

/* ─── ABOUT ─── */
.about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 90px; align-items: center; }
.about-img-main {
  position: relative; border-radius: var(--radius); overflow: hidden;
  aspect-ratio: 4/3;
}
.about-img-main img { width: 100%; height: 100%; object-fit: cover; display: block; }
.about-img-main::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(15,15,15,.6), transparent);
}
.about-float {
  position: absolute; bottom: -28px; right: -28px;
  background: var(--glass); backdrop-filter: blur(20px);
  border: 1px solid var(--glass-border); border-radius: var(--radius);
  padding: 22px 28px; z-index: 2;
}
.about-float-num { font-family: var(--font-head); font-size: 2.8rem; font-weight: 900; color: var(--silver-light); line-height: 1; }
.about-float-lbl { font-size: .65rem; letter-spacing: 3px; color: rgba(255,255,255,.4); text-transform: uppercase; margin-top: 4px; }
.about-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-top: 44px; }
.stat { border-top: 1px solid var(--glass-border); padding-top: 18px; }
.stat-n { font-family: var(--font-head); font-size: 2rem; font-weight: 800; color: var(--white); }
.stat-l { font-size: .68rem; letter-spacing: 2px; color: rgba(255,255,255,.35); text-transform: uppercase; margin-top: 4px; }

/* ─── PRODUCTS ─── */
.prod-grid {
  display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; margin-top: 70px;
}
.prod-card {
  background: var(--glass); border: 1px solid var(--glass-border);
  border-radius: var(--radius); overflow: hidden; transition: all .4s;
  backdrop-filter: blur(10px);
}
.prod-card:hover { border-color: var(--glass-border-hover); box-shadow: var(--shadow-hover); transform: translateY(-6px); }
.prod-img { width: 100%; height: 190px; object-fit: cover; display: block; transition: transform .5s; }
.prod-card:hover .prod-img { transform: scale(1.06); }
.prod-body { padding: 20px; }
.prod-cat {
  font-size: .6rem; letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--silver); font-weight: 600; margin-bottom: 8px;
}
.prod-name { font-family: var(--font-head); font-size: 1rem; font-weight: 700; letter-spacing: .5px; margin-bottom: 6px; }
.prod-desc { font-size: .75rem; color: rgba(255,255,255,.4); line-height: 1.7; margin-bottom: 10px; }
.prod-stars { display: flex; gap: 2px; margin-bottom: 14px; }
.prod-stars svg { width: 12px; height: 12px; fill: var(--silver-light); }
.prod-foot { display: flex; align-items: center; justify-content: space-between; }
.prod-price { font-family: var(--font-head); font-size: 1.1rem; font-weight: 800; color: var(--white); }
.btn-buy {
  background: var(--white); color: var(--black); font-family: var(--font-head);
  font-size: .65rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
  padding: 8px 16px; border-radius: var(--radius-sm); border: none; cursor: pointer; transition: all .3s;
}
.btn-buy:hover { background: var(--silver-light); box-shadow: 0 0 20px rgba(255,255,255,.1); }

/* ─── GALLERY ─── */
.gal-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: 220px;
  gap: 10px; margin-top: 70px;
}
.gal-item { overflow: hidden; border-radius: var(--radius-sm); position: relative; cursor: pointer; }
.gal-item:nth-child(1) { grid-column: span 2; grid-row: span 2; }
.gal-item:nth-child(5) { grid-column: span 2; }
.gal-item img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s; display: block; }
.gal-item:hover img { transform: scale(1.07); }
.gal-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,.75) 0%, transparent 50%);
  opacity: 0; transition: opacity .35s;
  display: flex; align-items: flex-end; padding: 20px;
}
.gal-item:hover .gal-overlay { opacity: 1; }
.gal-label { font-family: var(--font-head); font-size: .75rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--white); }

/* Lightbox */
#lbox {
  display: none; position: fixed; inset: 0; z-index: 9000;
  background: rgba(0,0,0,.95); backdrop-filter: blur(10px);
  align-items: center; justify-content: center;
}
#lbox.open { display: flex; }
#lbox img { max-width: 90vw; max-height: 90vh; object-fit: contain; border-radius: var(--radius); }
#lbox-close {
  position: absolute; top: 24px; right: 28px; cursor: pointer;
  background: none; border: none; color: rgba(255,255,255,.5);
  font-size: 1.6rem; transition: color .3s;
}
#lbox-close:hover { color: var(--white); }

/* ─── FEATURES ─── */
.feat-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; margin-top: 70px; }
.feat-card {
  background: var(--glass); border: 1px solid var(--glass-border);
  border-radius: var(--radius); padding: 36px 28px;
  transition: all .4s; position: relative; overflow: hidden;
  backdrop-filter: blur(10px);
}
.feat-card::before {
  content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--silver), transparent);
  opacity: 0; transition: opacity .4s;
}
.feat-card:hover { border-color: var(--glass-border-hover); transform: translateY(-5px); box-shadow: var(--glow-hover); }
.feat-card:hover::before { opacity: 1; }
.feat-icon { width: 48px; height: 48px; border: 1px solid var(--glass-border); border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 22px; }
.feat-icon svg { width: 22px; height: 22px; color: var(--silver); }
.feat-title { font-family: var(--font-head); font-size: 1rem; font-weight: 700; letter-spacing: .5px; margin-bottom: 12px; }
.feat-desc { font-size: .8rem; color: rgba(255,255,255,.4); line-height: 1.8; }

/* ─── TESTIMONIAL ─── */
.testi-swiper { margin-top: 70px; padding-bottom: 60px !important; }
.testi-card {
  background: var(--glass); border: 1px solid var(--glass-border);
  border-radius: var(--radius); padding: 40px; backdrop-filter: blur(16px);
  transition: border-color .3s, box-shadow .3s;
}
.testi-card:hover { border-color: var(--glass-border-hover); box-shadow: var(--glow); }
.testi-stars { display: flex; gap: 3px; margin-bottom: 18px; }
.testi-stars svg { width: 14px; height: 14px; fill: var(--silver-light); }
.testi-quote { font-size: .92rem; color: rgba(255,255,255,.7); line-height: 1.85; margin-bottom: 28px; font-style: italic; }
.testi-author { display: flex; align-items: center; gap: 14px; }
.testi-avatar { width: 52px; height: 52px; border-radius: 50%; object-fit: cover; border: 1px solid var(--glass-border); }
.testi-name { font-family: var(--font-head); font-size: .9rem; font-weight: 700; letter-spacing: .5px; }
.testi-role { font-size: .68rem; color: rgba(255,255,255,.35); letter-spacing: 1px; text-transform: uppercase; margin-top: 3px; }
.swiper-pagination-bullet { background: rgba(255,255,255,.2) !important; width: 6px !important; height: 6px !important; }
.swiper-pagination-bullet-active { background: var(--silver) !important; width: 24px !important; border-radius: 3px !important; }

/* ─── CONTACT ─── */
.contact-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; margin-top: 70px; }
.form-field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
.form-label { font-size: .65rem; letter-spacing: 2.5px; text-transform: uppercase; color: rgba(255,255,255,.35); font-weight: 600; }
.form-control {
  background: var(--glass); border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm); padding: 14px 18px;
  color: var(--white); font-family: var(--font-body); font-size: .88rem;
  outline: none; transition: border-color .3s, box-shadow .3s; width: 100%;
}
.form-control:focus { border-color: rgba(191,192,192,.4); box-shadow: 0 0 0 3px rgba(191,192,192,.06); }
.form-control::placeholder { color: rgba(255,255,255,.2); }
textarea.form-control { resize: vertical; min-height: 130px; }
.contact-info-list { display: flex; flex-direction: column; gap: 22px; }
.ci-item { display: flex; align-items: flex-start; gap: 16px; }
.ci-icon {
  width: 42px; height: 42px; flex-shrink: 0; border-radius: 10px;
  border: 1px solid var(--glass-border); background: var(--glass);
  display: flex; align-items: center; justify-content: center;
}
.ci-icon svg { width: 18px; height: 18px; color: var(--silver); }
.ci-lbl { font-size: .65rem; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,.3); margin-bottom: 4px; }
.ci-val { font-size: .88rem; color: var(--white); }
.ci-val a { color: var(--silver-light); text-decoration: none; transition: color .3s; }
.ci-val a:hover { color: var(--white); }
.map-frame { margin-top: 28px; border-radius: var(--radius); overflow: hidden; border: 1px solid var(--glass-border); }
.map-frame iframe { width: 100%; height: 220px; display: block; border: none; filter: grayscale(1) brightness(.7); transition: filter .4s; }
.map-frame:hover iframe { filter: grayscale(.6) brightness(.85); }

/* ─── FOOTER ─── */
footer {
  background: var(--black2); border-top: 1px solid var(--glass-border);
  padding: 70px 6% 32px;
}
.foot-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 60px; margin-bottom: 50px; }
.foot-logo { font-family: var(--font-head); font-size: 2rem; font-weight: 900; letter-spacing: 5px;
  background: linear-gradient(135deg,#888,#BFC0C0,#fff); -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  margin-bottom: 16px; display: block; }
.foot-desc { font-size: .82rem; color: rgba(255,255,255,.3); line-height: 1.9; max-width: 300px; }
.foot-social { display: flex; gap: 10px; margin-top: 24px; }
.soc-btn {
  width: 38px; height: 38px; border-radius: 8px; border: 1px solid var(--glass-border);
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,.4); text-decoration: none; transition: all .3s;
}
.soc-btn:hover { border-color: var(--silver); color: var(--white); box-shadow: var(--glow); }
.soc-btn svg { width: 16px; height: 16px; }
.foot-head { font-family: var(--font-head); font-size: .7rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--silver); margin-bottom: 20px; }
.foot-links { list-style: none; display: flex; flex-direction: column; gap: 12px; }
.foot-links a { font-size: .82rem; color: rgba(255,255,255,.35); text-decoration: none; transition: color .3s; display: inline-flex; align-items: center; gap: 6px; }
.foot-links a:hover { color: var(--white); }
.foot-bottom { border-top: 1px solid var(--glass-border); padding-top: 28px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
