<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
/* Loader */
window.addEventListener('load', () => {
  setTimeout(() => {
    const L = document.getElementById('loader');
    L.style.transition = 'opacity .6s ease';
    L.style.opacity = '0';
    setTimeout(() => L.style.display = 'none', 600);
  }, 2400);
});

/* Progress bar */
window.addEventListener('scroll', () => {
  const t = document.documentElement.scrollTop;
  const h = document.documentElement.scrollHeight - innerHeight;
  document.getElementById('progress').style.width = (t / h * 100) + '%';
});

/* Navbar */
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => nav.classList.toggle('stuck', scrollY > 60));

/* Active links */
const secs = document.querySelectorAll('section[id]');
const links = document.querySelectorAll('.nav-menu a');
window.addEventListener('scroll', () => {
  let cur = '';
  secs.forEach(s => { if (scrollY >= s.offsetTop - 200) cur = s.id; });
  links.forEach(a => { a.classList.toggle('active', a.getAttribute('href') === '#' + cur); });
});

/* Hamburger */
const hbg = document.getElementById('hbg');
const mob = document.getElementById('mobMenu');
hbg.addEventListener('click', () => { hbg.classList.toggle('open'); mob.classList.toggle('open'); });
function closeMenu() { hbg.classList.remove('open'); mob.classList.remove('open'); }

/* Swiper */
new Swiper('.testi-swiper', {
  slidesPerView: 1, spaceBetween: 24, loop: true,
  autoplay: { delay: 4500, disableOnInteraction: false },
  pagination: { el: '.swiper-pagination', clickable: true },
  breakpoints: { 768: { slidesPerView: 2 }, 1200: { slidesPerView: 3 } }
});

/* AOS */
AOS.init({ duration: 750, once: true, offset: 70, easing: 'ease-out-quad' });

/* Particles */
(function() {
  const c = document.getElementById('ptx');
  for (let i = 0; i < 18; i++) {
    const d = document.createElement('div');
    d.className = 'ptx-dot';
    const s = Math.random() * 3 + 1;
    d.style.cssText = `width:${s}px;height:${s}px;left:${Math.random()*100}%;animation-duration:${Math.random()*25+12}s;animation-delay:${Math.random()*20}s;opacity:${Math.random()*.3+.05}`;
    c.appendChild(d);
  }
})();

/* Lightbox */
function openLbox(el) {
  const img = el.querySelector('img');
  document.getElementById('lbox-img').src = img.src.replace('w=600','w=1200');
  document.getElementById('lbox').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeLbox() {
  document.getElementById('lbox').classList.remove('open');
  document.body.style.overflow = '';
}
document.getElementById('lbox').addEventListener('click', function(e) {
  if (e.target === this) closeLbox();
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLbox(); });

/* Buy feedback */
function addedFeedback(btn) {
  const orig = btn.textContent;
  btn.textContent = '✓ Added';
  btn.style.background = '#2D2D2D';
  btn.style.color = '#BFC0C0';
  setTimeout(() => { btn.textContent = orig; btn.style.background = ''; btn.style.color = ''; }, 1600);
}

/* Parallax hero */
window.addEventListener('scroll', () => {
  const s = scrollY;
  if (s < innerHeight) {
    const bg = document.querySelector('.hero-bg');
    const hc = document.querySelector('.hero-content');
    if (bg) bg.style.transform = `translateY(${s * 0.25}px)`;
    if (hc) { hc.style.transform = `translateY(${s * 0.18}px)`; hc.style.opacity = 1 - s / 650; }
  }
});
</script>
